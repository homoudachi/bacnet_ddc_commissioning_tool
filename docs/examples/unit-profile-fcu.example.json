{
  "schema_version": "0.1-example",
  "profile_id": "fcu_2pipe_chw_electric_heat_v1",
  "display_name": "FCU — 2-pipe CHW cooling + modulating electric heat + modulating supply fan",
  "description": "Illustrative import fragment. BACnet instances are placeholders. Half-design airflow uses a seamless flow: auto-adjust → confirm tachometer value → manual verify → heating.",
  "bacnet_device": {
    "device_instance": 21001,
    "address": {
      "type": "ipv4",
      "host": "192.168.1.50",
      "port": 47808
    }
  },
  "unit_specs": {
    "design_supply_airflow_L_s": 0.85,
    "design_return_airflow_L_s": null,
    "heater": {
      "type": "electric_modulating",
      "max_kw_at_100_percent": 2.0,
      "command_object_note": "Single AV 0–100% for heat output / staging demand as programmed"
    },
    "chw": {
      "type": "two_pipe",
      "valve_is_cooling_only": true,
      "valve_stroke_verify_without_plant": {
        "description": "Always run without chilled water: command valve 100%, technician confirms via prompt; command 0%, confirm again.",
        "valve_object_id": "ao_chw_valve"
      }
    }
  },
  "objects": [
    {
      "id": "msv_test_mode",
      "role": "commissioning_test_mode",
      "bacnet": { "object_type": "multiStateValue", "instance": 50 },
      "writable": true,
      "relinquish_default": 1,
      "states": [
        { "number": 1, "key": "normal", "label": "Normal operation" },
        { "number": 2, "key": "fan_tacho_verify", "label": "Fan tachometer verification" },
        { "number": 3, "key": "airflow_verify", "label": "Airflow verification" },
        { "number": 4, "key": "heating_test", "label": "Electric heating test" },
        { "number": 5, "key": "chw_test", "label": "Chilled-water cooling test (requires plant)" },
        { "number": 6, "key": "chw_valve_stroke_no_plant", "label": "Cooling valve stroke verify — no CHW" }
      ]
    },
    {
      "id": "av_supply_fan_tacho_value",
      "role": "supply_fan_tachometer_value",
      "bacnet": { "object_type": "analogValue", "instance": 1 },
      "writable": false,
      "signal": {
        "kind": "pulse_train_conditioned_by_controller",
        "engineering_units": "noSpecificUnits",
        "ui_label": "Tachometer value (not necessarily RPM)"
      }
    },
    {
      "id": "ai_sat",
      "role": "supply_air_temperature",
      "bacnet": { "object_type": "analogInput", "instance": 2 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "av_supply_fan_command",
      "role": "supply_fan_speed_command",
      "bacnet": { "object_type": "analogValue", "instance": 3 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "av_electric_heat_command",
      "role": "electric_heat_modulating_command",
      "bacnet": { "object_type": "analogValue", "instance": 4 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "ao_chw_valve",
      "role": "chilled_water_valve_command",
      "bacnet": { "object_type": "analogOutput", "instance": 5 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    }
  ],
  "temperature_inputs_for_heat_rise": {
    "sat_ref": { "object_id": "ai_sat" },
    "rat_equivalent": {
      "description": "No BACnet RAT on this FCU; use operator or external probe for return-side air temperature.",
      "allowed_sources": ["manual_entry", "bluetooth_probe"],
      "bacnet_object_id": null
    }
  },
  "commissioning_flow": [
    {
      "step_id": "half_design_airflow_auto",
      "label": "Automatic airflow adjustment to ~50% design",
      "description": "Tool modulates av_supply_fan_command using assisted balancing / measurement until measured flow is ~0.5 × design_supply_airflow_L_s.",
      "arms_test_mode_state_key": "airflow_verify",
      "actions": [
        {
          "type": "automatic_airflow_adjustment",
          "actuator_object_id": "av_supply_fan_command",
          "target_flow_ratio_of_design": 0.5,
          "measurement_branch_id": "supply_terminal_main",
          "tolerance_ratio": 0.05
        }
      ]
    },
    {
      "step_id": "confirm_tachometer_reference_half_flow",
      "label": "Confirm tachometer value at this operating point",
      "description": "Technician confirms the BACnet tachometer value read while at ~half design flow; stored as reference for heat interlock.",
      "actions": [
        {
          "type": "operator_confirm_tachometer_reference",
          "read_object_id": "av_supply_fan_tacho_value",
          "session_key": "fan_tachometer_reference_at_half_design_flow"
        }
      ]
    },
    {
      "step_id": "manual_airflow_verify_half_then_design",
      "label": "Manual airflow verification (same workflow)",
      "description": "Assisted measurement vs design (L/s); continues seamlessly from prior steps.",
      "arms_test_mode_state_key": "airflow_verify",
      "actions": [
        {
          "type": "manual_airflow_verification_assisted",
          "branch_ids": ["supply_terminal_main"]
        }
      ]
    },
    {
      "step_id": "cooling_valve_stroke_no_chw",
      "label": "Cooling valve stroke — no CHW (100% then 0%)",
      "description": "No chilled-water plant required. Command ao_chw_valve to 100%; technician confirms full stroke / end travel via prompt. Then command to 0%; confirm closed / zero via prompt.",
      "arms_test_mode_state_key": "chw_valve_stroke_no_plant",
      "actions": [
        {
          "type": "write_analog_percent",
          "object_id": "ao_chw_valve",
          "value": 100
        },
        {
          "type": "operator_prompt_confirm",
          "prompt_id": "chw_valve_at_100",
          "prompt_text": "Confirm the cooling valve has driven to the full open (100%) position — travel, mechanical stop, or local indicator as applicable."
        },
        {
          "type": "write_analog_percent",
          "object_id": "ao_chw_valve",
          "value": 0
        },
        {
          "type": "operator_prompt_confirm",
          "prompt_id": "chw_valve_at_0",
          "prompt_text": "Confirm the cooling valve has returned to fully closed (0%) — no cooling demand at stem / indicator as applicable."
        }
      ]
    },
    {
      "step_id": "heating_test",
      "label": "Heating test (modulating heat AV)",
      "description": "Only offered after half-flow tachometer reference is stored and manual airflow step acknowledged per UI rules.",
      "arms_test_mode_state_key": "heating_test",
      "requires_session_keys": ["fan_tachometer_reference_at_half_design_flow"],
      "actions": [
        {
          "type": "modulate_heat_and_fan_per_program",
          "heat_object_id": "av_electric_heat_command",
          "fan_object_id": "av_supply_fan_command",
          "target": "approach_design_delta_t_and_flow"
        }
      ]
    }
  ],
  "interlocks": [
    {
      "id": "heat_allowed_when_tachometer_proves_half_flow",
      "applies_when_test_modes": ["heating_test"],
      "requires_session_keys": ["fan_tachometer_reference_at_half_design_flow"],
      "description": "Live tachometer value must stay at or above the stored reference (captured after auto half-flow + confirm), not a guessed RPM curve.",
      "expression": "presentValue(av_supply_fan_tacho_value) >= session.fan_tachometer_reference_at_half_design_flow - hysteresis",
      "hysteresis_tachometer_value": 0
    }
  ],
  "airflow_verification": {
    "design_reference_flow_L_s": 0.85,
    "branches": [
      {
        "id": "supply_terminal_main",
        "label": "Primary supply outlet / grille",
        "design_flow_L_s": 0.85,
        "measurement": {
          "default_tool": "balometer",
          "allowed_tools": ["balometer", "pitot_traverse", "hot_wire_grid"],
          "tolerance_percent": 10,
          "notes": "Assisted balancing: predictable steps—adjust fan command, compare to target L/s, repeat until within tolerance."
        }
      }
    ]
  },
  "tests": [
    {
      "id": "fan_tachometer_sanity",
      "test_mode_state_key": "fan_tacho_verify",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "fan_tacho_verify"
        },
        {
          "action": "read_until_stable",
          "object_id": "av_supply_fan_tacho_value",
          "stable_seconds": 5
        }
      ],
      "pass_criteria": {
        "type": "tachometer_value_threshold",
        "comparison": "greater_than",
        "value": 0,
        "comment": "Replace with profile-specific floor when you know controller scaling"
      }
    },
    {
      "id": "heating_after_prerequisites",
      "test_mode_state_key": "heating_test",
      "depends_on_interlocks": ["heat_allowed_when_tachometer_proves_half_flow"],
      "depends_on_commissioning_steps_completed": [
        "half_design_airflow_auto",
        "confirm_tachometer_reference_half_flow",
        "manual_airflow_verify_half_then_design"
      ],
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "heating_test"
        },
        {
          "action": "modulate_to_target",
          "description": "Tool drives av_supply_fan_command and av_electric_heat_command within limits; SAT/RAT per session/manual/Bluetooth.",
          "actuator_object_ids": ["av_supply_fan_command", "av_electric_heat_command"],
          "target": "approach_design_delta_t_and_flow"
        }
      ],
      "manual_verification_required": true
    },
    {
      "id": "cooling_valve_stroke_no_plant_test",
      "test_mode_state_key": "chw_valve_stroke_no_plant",
      "description": "Standalone test card matching commissioning_flow cooling_valve_stroke_no_chw.",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "chw_valve_stroke_no_plant"
        },
        {
          "action": "write_analog_percent",
          "object_id": "ao_chw_valve",
          "value": 100
        },
        {
          "action": "operator_prompt_confirm",
          "prompt_id": "chw_valve_at_100",
          "prompt_text": "Confirm cooling valve at 100% (full open / stroke verified)."
        },
        {
          "action": "write_analog_percent",
          "object_id": "ao_chw_valve",
          "value": 0
        },
        {
          "action": "operator_prompt_confirm",
          "prompt_id": "chw_valve_at_0",
          "prompt_text": "Confirm cooling valve at 0% (fully closed)."
        }
      ],
      "manual_verification_required": true
    }
  ]
}
