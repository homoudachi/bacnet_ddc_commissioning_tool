{
  "schema_version": "0.1-example",
  "profile_id": "hrv_counterflow_erv_v1",
  "display_name": "HRV / energy-recovery ventilator — supply + exhaust, current-switch fan proof",
  "description": "Illustrative fragment: two airstreams, no electric heat. One BI (current switch) on the fan motor circuit; fans run just below half design speed to satisfy prove. Airflow is manually verified with tool assistance.",
  "bacnet_device": {
    "device_instance": 22001,
    "address": {
      "type": "ipv4",
      "host": "192.168.1.60",
      "port": 47808
    }
  },
  "unit_specs": {
    "design_supply_airflow_L_s": 47.2,
    "design_exhaust_airflow_L_s": 45.0,
    "design_outdoor_airflow_L_s": 47.2,
    "design_return_to_core_airflow_L_s": 45.0,
    "comment": "No heater on this profile. Naming of streams should match shop drawings."
  },
  "objects": [
    {
      "id": "msv_test_mode",
      "role": "commissioning_test_mode",
      "bacnet": { "object_type": "multiStateValue", "instance": 60 },
      "writable": true,
      "relinquish_default": 1,
      "states": [
        { "number": 1, "key": "normal", "label": "Normal operation" },
        { "number": 2, "key": "fan_tacho_supply", "label": "Supply fan tachometer verification" },
        { "number": 3, "key": "fan_tacho_exhaust", "label": "Exhaust fan tachometer verification" },
        { "number": 4, "key": "airflow_verify_supply", "label": "Supply airflow verification" },
        { "number": 5, "key": "airflow_verify_exhaust", "label": "Exhaust (return) airflow verification" },
        { "number": 6, "key": "heat_recovery_balance", "label": "Heat-recovery balance / flow ratio check" },
        { "number": 7, "key": "defrost_or_frost_test", "label": "Defrost / frost protection test (if applicable)" }
      ]
    },
    {
      "id": "bi_fan_motor_current_switch",
      "role": "fan_motor_current_switch_single_circuit",
      "description": "One current switch on the fan circuit; proves both fans when wired per your panel.",
      "bacnet": { "object_type": "binaryInput", "instance": 9 },
      "writable": false,
      "polarity": "active_on_current_detected"
    },
    {
      "id": "av_supply_fan_tacho_value",
      "role": "supply_fan_tachometer_value",
      "bacnet": { "object_type": "analogValue", "instance": 10 },
      "writable": false,
      "signal": {
        "kind": "pulse_train_conditioned_by_controller",
        "engineering_units": "noSpecificUnits",
        "ui_label": "Supply tachometer value"
      }
    },
    {
      "id": "av_exhaust_fan_tacho_value",
      "role": "exhaust_fan_tachometer_value",
      "bacnet": { "object_type": "analogValue", "instance": 11 },
      "writable": false,
      "signal": {
        "kind": "pulse_train_conditioned_by_controller",
        "engineering_units": "noSpecificUnits",
        "ui_label": "Exhaust tachometer value"
      }
    },
    {
      "id": "av_supply_fan_command",
      "role": "supply_fan_speed_command",
      "bacnet": { "object_type": "analogValue", "instance": 12 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "av_exhaust_fan_command",
      "role": "exhaust_fan_speed_command",
      "bacnet": { "object_type": "analogValue", "instance": 13 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "ai_oa_temperature",
      "role": "outdoor_air_temperature",
      "bacnet": { "object_type": "analogInput", "instance": 14 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "ai_supply_air_temperature",
      "role": "supply_air_temperature_downstream_of_core",
      "bacnet": { "object_type": "analogInput", "instance": 15 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "ai_exhaust_air_temperature",
      "role": "exhaust_air_temperature_upstream_or_downstream_per_program",
      "bacnet": { "object_type": "analogInput", "instance": 16 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    }
  ],
  "commissioning_flow": [
    {
      "step_id": "current_switch_prove_just_below_half",
      "label": "Set fans just below half design speed; verify current switch BI",
      "description": "Single BI for the fan circuit: modulate av_supply_fan_command and av_exhaust_fan_command to slightly under 0.5 × design on each stream (per your program’s mapping), then technician confirms BI = RUN/current detected.",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "automatic_airflow_adjustment_dual_fan",
          "target_flow_ratio_of_design_each_stream": 0.48,
          "comment": "Just below half—tune ratio (e.g. 0.48–0.49) per controller program",
          "supply_fan_object_id": "av_supply_fan_command",
          "exhaust_fan_object_id": "av_exhaust_fan_command",
          "supply_measurement_branch_id": "outdoor_supply_main",
          "exhaust_measurement_branch_id": "exhaust_return_main"
        },
        {
          "type": "operator_confirm_binary_input",
          "object_id": "bi_fan_motor_current_switch",
          "expected_state": "active"
        }
      ]
    },
    {
      "step_id": "manual_airflow_assisted_supply",
      "label": "Manual supply airflow verification (assisted)",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "manual_airflow_verification_assisted",
          "branch_ids": ["outdoor_supply_main"]
        }
      ]
    },
    {
      "step_id": "manual_airflow_assisted_exhaust",
      "label": "Manual exhaust airflow verification (assisted)",
      "arms_test_mode_state_key": "airflow_verify_exhaust",
      "actions": [
        {
          "type": "manual_airflow_verification_assisted",
          "branch_ids": ["exhaust_return_main"]
        }
      ]
    },
    {
      "step_id": "optional_recovery_balance",
      "label": "Optional: heat-recovery balance check",
      "arms_test_mode_state_key": "heat_recovery_balance",
      "actions": [
        {
          "type": "prompt_measure_both_streams",
          "branch_ids": ["outdoor_supply_main", "exhaust_return_main"]
        }
      ]
    }
  ],
  "airflow_verification": {
    "branches": [
      {
        "id": "outdoor_supply_main",
        "label": "Outdoor-air / supply side — main duct",
        "design_flow_L_s": 47.2,
        "measurement": {
          "default_tool": "pitot_traverse",
          "allowed_tools": ["pitot_traverse", "balometer", "hot_wire_grid"],
          "tolerance_percent": 10
        }
      },
      {
        "id": "exhaust_return_main",
        "label": "Exhaust (return) side — main duct",
        "design_flow_L_s": 45.0,
        "measurement": {
          "default_tool": "pitot_traverse",
          "allowed_tools": ["pitot_traverse", "balometer", "hot_wire_grid"],
          "tolerance_percent": 10
        }
      }
    ],
    "assisted_balancing": {
      "description": "Same predictable step order for every HRV of this profile: prove BI near half flow, then assisted manual L/s on each stream."
    }
  },
  "tests": [
    {
      "id": "supply_fan_tachometer_read",
      "test_mode_state_key": "fan_tacho_supply",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "fan_tacho_supply"
        },
        {
          "action": "read_until_stable",
          "object_id": "av_supply_fan_tacho_value",
          "stable_seconds": 5
        }
      ],
      "pass_criteria": {
        "type": "tachometer_value_threshold",
        "comparison": "greater_than",
        "value": 0
      }
    },
    {
      "id": "exhaust_fan_tachometer_read",
      "test_mode_state_key": "fan_tacho_exhaust",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "fan_tacho_exhaust"
        },
        {
          "action": "read_until_stable",
          "object_id": "av_exhaust_fan_tacho_value",
          "stable_seconds": 5
        }
      ],
      "pass_criteria": {
        "type": "tachometer_value_threshold",
        "comparison": "greater_than",
        "value": 0
      }
    },
    {
      "id": "dual_stream_flow_within_tolerance",
      "test_mode_state_key": "heat_recovery_balance",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "heat_recovery_balance"
        },
        {
          "action": "prompt_measure_both_streams",
          "branch_ids": ["outdoor_supply_main", "exhaust_return_main"]
        }
      ],
      "pass_criteria": {
        "type": "both_streams_within_tolerance_percent_of_design",
        "tolerance_percent": 10
      },
      "manual_verification_required": true
    }
  ]
}
