{
  "schema_version": "0.1-example",
  "profile_id": "hrv_counterflow_erv_v1",
  "display_name": "HRV / energy-recovery ventilator — supply + exhaust, current-switch fan proof",
  "description": "Illustrative fragment: two airstreams, no electric heat. One BI (current switch) on the fan motor circuit: first balance measured supply and exhaust each to half design L/s, reduce fan commands by a relative fraction (default 20%), then field-adjust the current switch so BI just picks up. Airflow manually verified with tool assistance.",
  "bacnet_device": {
    "device_instance": 22001,
    "address": {
      "type": "ipv4",
      "host": "192.168.1.60",
      "port": 47808
    }
  },
  "commissioning_write_allowlist": [
    "msv_test_mode",
    "av_supply_fan_command",
    "av_exhaust_fan_command"
  ],
  "commissioning_read_allowlist": [
    "msv_test_mode",
    "ai_supply_air_temperature",
    "av_supply_fan_command",
    "av_exhaust_fan_command"
  ],
  "point_checkout": [
    { "object_id": "msv_test_mode", "property": "presentValue" },
    { "object_id": "av_supply_fan_command", "property": "presentValue" },
    { "object_id": "av_exhaust_fan_command", "property": "presentValue" }
  ],
  "unit_specs": {
    "design_supply_airflow_L_s": 47.2,
    "design_exhaust_airflow_L_s": 45.0,
    "design_outdoor_airflow_L_s": 47.2,
    "design_return_to_core_airflow_L_s": 45.0,
    "comment": "No heater on this profile. Naming of streams should match shop drawings.",
    "current_switch_commissioning": {
      "reduce_fan_command_relative_percent_after_measured_half": 20,
      "comment": "Relative reduction: new_command = old_command * (1 - percent/100). Example 40% -> 32% at 20% relative. Tune per site (15% relative was discussed)."
    }
  },
  "objects": [
    {
      "id": "msv_test_mode",
      "role": "commissioning_test_mode",
      "bacnet": { "object_type": "multiStateValue", "instance": 60 },
      "writable": true,
      "relinquish_default": 1,
      "states": [
        { "number": 1, "key": "normal", "label": "Normal operation" },
        { "number": 2, "key": "fan_tacho_supply", "label": "Supply fan tachometer verification" },
        { "number": 3, "key": "fan_tacho_exhaust", "label": "Exhaust fan tachometer verification" },
        { "number": 4, "key": "airflow_verify_supply", "label": "Supply airflow verification" },
        { "number": 5, "key": "airflow_verify_exhaust", "label": "Exhaust (return) airflow verification" },
        { "number": 6, "key": "heat_recovery_balance", "label": "Heat-recovery balance / flow ratio check" },
        { "number": 7, "key": "defrost_or_frost_test", "label": "Defrost / frost protection test (if applicable)" },
        { "number": 8, "key": "heat_recovery_sensors_test", "label": "Heat recovery — OAT/RAT/SAT logging at multiple fan speeds" }
      ]
    },
    {
      "id": "bi_fan_motor_current_switch",
      "role": "fan_motor_current_switch_single_circuit",
      "description": "One current switch on the fan circuit; proves both fans when wired per your panel.",
      "bacnet": { "object_type": "binaryInput", "instance": 9 },
      "writable": false,
      "polarity": "active_on_current_detected"
    },
    {
      "id": "av_supply_fan_tacho_value",
      "role": "supply_fan_tachometer_value",
      "bacnet": { "object_type": "analogValue", "instance": 10 },
      "writable": false,
      "signal": {
        "kind": "pulse_train_conditioned_by_controller",
        "engineering_units": "noSpecificUnits",
        "ui_label": "Supply tachometer value"
      }
    },
    {
      "id": "av_exhaust_fan_tacho_value",
      "role": "exhaust_fan_tachometer_value",
      "bacnet": { "object_type": "analogValue", "instance": 11 },
      "writable": false,
      "signal": {
        "kind": "pulse_train_conditioned_by_controller",
        "engineering_units": "noSpecificUnits",
        "ui_label": "Exhaust tachometer value"
      }
    },
    {
      "id": "av_supply_fan_command",
      "role": "supply_fan_speed_command",
      "bacnet": { "object_type": "analogValue", "instance": 12 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "av_exhaust_fan_command",
      "role": "exhaust_fan_speed_command",
      "bacnet": { "object_type": "analogValue", "instance": 13 },
      "writable": true,
      "engineering_units": "percent",
      "limits": { "min_write": 0, "max_write": 100 }
    },
    {
      "id": "ai_oa_temperature",
      "role": "outdoor_air_temperature",
      "bacnet": { "object_type": "analogInput", "instance": 14 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "ai_supply_air_temperature",
      "role": "supply_air_temperature_downstream_of_core",
      "bacnet": { "object_type": "analogInput", "instance": 15 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "ai_exhaust_air_temperature",
      "role": "exhaust_air_temperature_upstream_or_downstream_per_program",
      "bacnet": { "object_type": "analogInput", "instance": 16 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    },
    {
      "id": "ai_return_air_temperature",
      "role": "return_air_temperature_space_or_return_duct",
      "bacnet": { "object_type": "analogInput", "instance": 17 },
      "writable": false,
      "engineering_units": "degreesCelsius"
    }
  ],
  "heat_recovery_testing": {
    "description": "OAT, RAT, SAT available on BACnet — log at multiple paired fan speeds; optional sensible effectiveness check.",
    "sensors": {
      "outdoor_air_temp_object_id": "ai_oa_temperature",
      "return_air_temp_object_id": "ai_return_air_temperature",
      "supply_air_temp_object_id": "ai_supply_air_temperature",
      "exhaust_air_temp_object_id": "ai_exhaust_air_temperature"
    },
    "fan_speed_matrix_percent": [
      { "supply_percent": 40, "exhaust_percent": 40, "label": "Low" },
      { "supply_percent": 70, "exhaust_percent": 70, "label": "Mid" },
      { "supply_percent": 100, "exhaust_percent": 100, "label": "Design" }
    ],
    "dwell_seconds_per_speed": 180,
    "optional_calculated_effectiveness": {
      "enabled": true,
      "comment": "Sensible effectiveness-style check is only valid when sensor locations match the formula assumptions — treat as advisory; see pass-fail-defaults.recommended.md",
      "formula_hint": "Compare temperature cross against (T_exhaust_in - T_oa_in) using ai_exhaust_air_temperature vs ai_oa_temperature and supply side SAT; refine equation per your core geometry in profile v2."
    },
    "report_table_columns": [
      { "key": "timestamp", "label": "Time" },
      { "key": "supply_fan_percent", "object_id": "av_supply_fan_command" },
      { "key": "exhaust_fan_percent", "object_id": "av_exhaust_fan_command" },
      { "key": "oat_c", "object_id": "ai_oa_temperature" },
      { "key": "rat_c", "object_id": "ai_return_air_temperature" },
      { "key": "sat_c", "object_id": "ai_supply_air_temperature" },
      { "key": "exhaust_air_c", "object_id": "ai_exhaust_air_temperature" },
      { "key": "effectiveness_calc_advisory", "source": "optional_calculated_effectiveness" }
    ]
  },
  "commissioning_flow": [
    {
      "step_id": "hrv_balance_measured_flow_to_half_design_each_stream",
      "label": "HRV — balance supply and exhaust to half of design (measured L/s)",
      "description": "Adjust av_supply_fan_command and av_exhaust_fan_command until assisted measurements show each stream at ~0.5 × its design_flow_L_s (supply and return/exhaust branches independently).",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "automatic_airflow_adjustment_dual_fan",
          "target_measured_flow_ratio_of_design_each_stream": 0.5,
          "supply_fan_object_id": "av_supply_fan_command",
          "exhaust_fan_object_id": "av_exhaust_fan_command",
          "supply_measurement_branch_id": "outdoor_supply_main",
          "exhaust_measurement_branch_id": "exhaust_return_main"
        }
      ]
    },
    {
      "step_id": "hrv_reduce_fan_commands_after_half",
      "label": "Reduce both fan commands (relative %) from that operating point",
      "description": "From the half-design measured point, multiply each fan AV by (1 - P/100) where P = unit_specs.current_switch_commissioning.reduce_fan_command_relative_percent_after_measured_half (default 20 = 20% relative reduction).",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "reduce_fan_speed_commands_by_relative_percent",
          "relative_percent": 20,
          "formula": "new_value = present_value * (1 - relative_percent/100)",
          "relative_to": "commands_at_measured_half_design",
          "object_ids": ["av_supply_fan_command", "av_exhaust_fan_command"]
        }
      ]
    },
    {
      "step_id": "hrv_field_set_current_switch_pickup",
      "label": "Field-adjust current switch so BI just comes on at this speed",
      "description": "Technician adjusts the physical current switch setpoint so the BI transitions to active at this reduced-flow operating point (just picks up).",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "field_adjust_current_switch_until_bi_active",
          "bi_object_id": "bi_fan_motor_current_switch",
          "instruction": "Adjust current switch until BI reads ON/current detected at this fan speed; avoid tripping at idle."
        },
        {
          "type": "operator_confirm_binary_input",
          "object_id": "bi_fan_motor_current_switch",
          "expected_state": "active"
        }
      ]
    },
    {
      "step_id": "manual_airflow_assisted_supply",
      "label": "Manual supply airflow verification (assisted)",
      "arms_test_mode_state_key": "airflow_verify_supply",
      "actions": [
        {
          "type": "manual_airflow_verification_assisted",
          "branch_ids": ["outdoor_supply_main"]
        }
      ]
    },
    {
      "step_id": "manual_airflow_assisted_exhaust",
      "label": "Manual exhaust airflow verification (assisted)",
      "arms_test_mode_state_key": "airflow_verify_exhaust",
      "actions": [
        {
          "type": "manual_airflow_verification_assisted",
          "branch_ids": ["exhaust_return_main"]
        }
      ]
    },
    {
      "step_id": "optional_recovery_balance",
      "label": "Optional: heat-recovery balance check",
      "arms_test_mode_state_key": "heat_recovery_balance",
      "actions": [
        {
          "type": "prompt_measure_both_streams",
          "branch_ids": ["outdoor_supply_main", "exhaust_return_main"]
        }
      ]
    },
    {
      "step_id": "hrv_heat_recovery_sensor_matrix",
      "label": "Heat recovery — OAT, RAT, SAT at multiple fan speeds",
      "description": "Step through heat_recovery_testing.fan_speed_matrix_percent; dwell; log OAT/RAT/SAT/exhaust temps; run optional calculated effectiveness when enabled.",
      "arms_test_mode_state_key": "heat_recovery_sensors_test",
      "actions": [
        {
          "type": "set_fan_speeds_and_log_recovery_sensors",
          "ref": "heat_recovery_testing"
        }
      ]
    }
  ],
  "airflow_verification": {
    "branches": [
      {
        "id": "outdoor_supply_main",
        "label": "Outdoor-air / supply side — main duct",
        "design_flow_L_s": 47.2,
        "measurement": {
          "default_tool": "pitot_traverse",
          "allowed_tools": ["pitot_traverse", "balometer", "hot_wire_grid"],
          "tolerance_percent": 10
        }
      },
      {
        "id": "exhaust_return_main",
        "label": "Exhaust (return) side — main duct",
        "design_flow_L_s": 45.0,
        "measurement": {
          "default_tool": "pitot_traverse",
          "allowed_tools": ["pitot_traverse", "balometer", "hot_wire_grid"],
          "tolerance_percent": 10
        }
      }
    ],
    "assisted_balancing": {
      "description": "Predictable order: measured half-design on supply and exhaust → reduce fan commands (relative %, default 20%) → adjust current switch for BI pickup → assisted manual L/s verification per branch."
    }
  },
  "tests": [
    {
      "id": "supply_fan_tachometer_read",
      "test_mode_state_key": "fan_tacho_supply",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "fan_tacho_supply"
        },
        {
          "action": "read_until_stable",
          "object_id": "av_supply_fan_tacho_value",
          "stable_seconds": 5
        }
      ],
      "pass_criteria": {
        "type": "tachometer_value_threshold",
        "comparison": "greater_than",
        "value": 0
      }
    },
    {
      "id": "exhaust_fan_tachometer_read",
      "test_mode_state_key": "fan_tacho_exhaust",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "fan_tacho_exhaust"
        },
        {
          "action": "read_until_stable",
          "object_id": "av_exhaust_fan_tacho_value",
          "stable_seconds": 5
        }
      ],
      "pass_criteria": {
        "type": "tachometer_value_threshold",
        "comparison": "greater_than",
        "value": 0
      }
    },
    {
      "id": "hrv_heat_recovery_oat_rat_sat_matrix",
      "test_mode_state_key": "heat_recovery_sensors_test",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "heat_recovery_sensors_test"
        },
        {
          "action": "set_fan_speeds_and_log_recovery_sensors",
          "ref": "heat_recovery_testing"
        }
      ],
      "manual_verification_required": false,
      "pass_criteria": {
        "type": "advisory_effectiveness_within_band_if_calculated",
        "comment": "See docs/examples/pass-fail-defaults.recommended.md HRV section"
      }
    },
    {
      "id": "dual_stream_flow_within_tolerance",
      "test_mode_state_key": "heat_recovery_balance",
      "steps": [
        {
          "action": "write_msv_state",
          "object_id": "msv_test_mode",
          "state_key": "heat_recovery_balance"
        },
        {
          "action": "prompt_measure_both_streams",
          "branch_ids": ["outdoor_supply_main", "exhaust_return_main"]
        }
      ],
      "pass_criteria": {
        "type": "both_streams_within_tolerance_percent_of_design",
        "tolerance_percent": 10
      },
      "manual_verification_required": true
    }
  ]
}
